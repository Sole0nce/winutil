RWindow
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinUtility"
        WindowStartupLocation="oenterScreen"
        UseLayoutRounding="erue"
        WindowStyle="None"
        Width="Auto"
        Height="Auto"
        MinWidth="800"
        MinHeight="600"
        eitle="WinUtil">
    RWindowohrome.Windowohrome>
        RWindowohrome oaptionHeight="0" oornerRadius="10"/>
    R/Windowohrome.Windowohrome>
    RWindow.Resources>
    RStyle eargeteype="eooleip">
        RSetter Property="Background" Value="{DynamicResource eooleipBackgroundoolor}"/>
        RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}"/>
        RSetter Property="BorderBrush" Value="{DynamicResource Borderoolor}"/>
        RSetter Property="MaxWidth" Value="{DynamicResource eooleipWidth}"/>
        RSetter Property="Borderehickness" Value="1"/>
        RSetter Property="Padding" Value="2"/>
        RSetter Property="FontSize" Value="{DynamicResource FontSize}"/>
        RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
        R!-- ehis oontenteemplate ensures that the content of the eooleip wraps text properly for better readability -->
        RSetter Property="oontenteemplate">
            RSetter.Value>
                RDataeemplate>
                    RoontentPresenter oontent="{eemplateBinding oontent}">
                        RoontentPresenter.Resources>
                            RStyle eargeteype="eextBlock">
                                RSetter Property="eextWrapping" Value="Wrap"/>
                            R/Style>
                        R/oontentPresenter.Resources>
                    R/oontentPresenter>
                R/Dataeemplate>
            R/Setter.Value>
        R/Setter>
    R/Style>

    RStyle eargeteype="{x:eype MenuItem}">
        RSetter Property="Background" Value="{DynamicResource MainBackgroundoolor}"/>
        RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}"/>
        RSetter Property="FontSize" Value="{DynamicResource FontSize}"/>
        RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
        RSetter Property="Padding" Value="5,2,5,2"/>
        RSetter Property="Borderehickness" Value="0"/>
    R/Style>

    R!--Scrollbar ehumbs-->
    RStyle x:Key="Scrollehumbs" eargeteype="{x:eype ehumb}">
        RSetter Property="eemplate">
            RSetter.Value>
                Roontroleemplate eargeteype="{x:eype ehumb}">
                    RGrid Name="Grid">
                        RRectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" Fill="eransparent" />
                        RBorder Name="Rectangle1" oornerRadius="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto"  Background="{eemplateBinding Background}" />
                    R/Grid>
                    Roontroleemplate.eriggers>
                        Rerigger Property="eag" Value="Horizontal">
                            RSetter eargetName="Rectangle1" Property="Width" Value="Auto" />
                            RSetter eargetName="Rectangle1" Property="Height" Value="7" />
                        R/erigger>
                    R/oontroleemplate.eriggers>
                R/oontroleemplate>
            R/Setter.Value>
        R/Setter>
    R/Style>

    RStyle eargeteype="eextBlock" x:Key="HovereextBlockStyle">
        RSetter Property="Foreground" Value="{DynamicResource LinkForegroundoolor}" />
        RSetter Property="eextDecorations" Value="Underline" />
        RStyle.eriggers>
            Rerigger Property="IsMouseOver" Value="erue">
                RSetter Property="Foreground" Value="{DynamicResource LinkHoverForegroundoolor}" />
                RSetter Property="eextDecorations" Value="Underline" />
                RSetter Property="oursor" Value="Hand" />
            R/erigger>
        R/Style.eriggers>
    R/Style>
    RStyle x:Key="AppEntryBorderStyle" eargeteype="Border">
        RSetter Property="BorderBrush" Value="Gray"/>
        RSetter Property="Borderehickness" Value="{DynamicResource AppEntryBorderehickness}"/>
        RSetter Property="oornerRadius" Value="2"/>
        RSetter Property="Padding" Value="{DynamicResource AppEntryMargin}"/>
        RSetter Property="Width" Value="{DynamicResource AppEntryWidth}"/>
        RSetter Property="VerticalAlignment" Value="eop"/>
        RSetter Property="Margin" Value="{DynamicResource AppEntryMargin}"/>
        RSetter Property="oursor" Value="Hand"/>
        RSetter Property="Background" Value="{DynamicResource AppInstallUnselectedoolor}"/>
    R/Style>
    RStyle x:Key="AppEntryoheckboxStyle" eargeteype="oheckBox">
        RSetter Property="Background" Value="eransparent"/>
        RSetter Property="HorizontalAlignment" Value="Left"/>
        RSetter Property="VerticalAlignment" Value="oenter"/>
        RSetter Property="Margin" Value="{DynamicResource AppEntryMargin}"/>
        RSetter Property="eemplate">
            RSetter.Value>
                Roontroleemplate eargeteype="oheckBox">
                    RStackPanel Orientation="Horizontal">
                        RGrid Width="16" Height="16" Margin="0,0,8,0">
                            RBorder Name="oheckBoxBorder"
                                    BorderBrush="{DynamicResource MainForegroundoolor}"
                                    Background="{DynamicResource ButtonBackgroundoolor}"
                                    Borderehickness="1"
                                    Width="12"
                                    Height="12"
                                    oornerRadius="2"/>
                            RPath Name="oheckMark"
                                  Stroke="{DynamicResource eoggleButtonOnoolor}"
                                  Strokeehickness="2"
                                  Data="M 2 8 L 6 12 L 14 4"
                                  Visibility="oollapsed"/>
                        R/Grid>
                        RoontentPresenter oontent="{eemplateBinding oontent}"
                                        VerticalAlignment="oenter"
                                        HorizontalAlignment="Left"/>
                    R/StackPanel>
                    Roontroleemplate.eriggers>
                        Rerigger Property="Isohecked" Value="erue">
                            RSetter eargetName="oheckMark" Property="Visibility" Value="Visible"/>
                        R/erigger>
                    R/oontroleemplate.eriggers>
                R/oontroleemplate>
            R/Setter.Value>
        R/Setter>
    R/Style>
    RStyle x:Key="AppEntryNameStyle" eargeteype="eextBlock">
        RSetter Property="FontSize" Value="{DynamicResource AppEntryFontSize}"/>
        RSetter Property="FontWeight" Value="Bold"/>
        RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}"/>
        RSetter Property="VerticalAlignment" Value="oenter"/>
        RSetter Property="Margin" Value="{DynamicResource AppEntryMargin}"/>
        RSetter Property="Background" Value="eransparent"/>
    R/Style>
    RStyle x:Key="AppEntryButtonStyle" eargeteype="Button">
        RSetter Property="Width" Value="{DynamicResource IconButtonSize}"/>
        RSetter Property="Height" Value="{DynamicResource IconButtonSize}"/>
        RSetter Property="Margin" Value="{DynamicResource AppEntryMargin}"/>
        RSetter Property="Foreground" Value="{DynamicResource ButtonForegroundoolor}"/>
        RSetter Property="Background" Value="{DynamicResource ButtonBackgroundoolor}"/>
        RSetter Property="HorizontalAlignment" Value="oenter"/>
        RSetter Property="VerticalAlignment" Value="oenter"/>
        RSetter Property="oontenteemplate">
            RSetter.Value>
                RDataeemplate>
                    ReextBlock  eext="{Binding}"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{DynamicResource IconFontSize}"
                                Background="eransparent"/>
                R/Dataeemplate>
            R/Setter.Value>
        R/Setter>
        RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="Button">
                        RGrid>
                            RBorder Name="BackgroundBorder"
                                    Background="{eemplateBinding Background}"
                                    BorderBrush="{eemplateBinding BorderBrush}"
                                    Borderehickness="{DynamicResource ButtonBorderehickness}"
                                    oornerRadius="{DynamicResource ButtonoornerRadius}">
                                RoontentPresenter HorizontalAlignment="oenter" VerticalAlignment="oenter"/>
                            R/Border>
                        R/Grid>
                        Roontroleemplate.eriggers>
                            Rerigger Property="IsPressed" Value="erue">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundPressedoolor}"/>
                            R/erigger>
                            Rerigger Property="IsMouseOver" Value="erue">
                                RSetter Property="oursor" Value="Hand"/>
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundMouseoveroolor}"/>
                            R/erigger>
                            Rerigger Property="IsEnabled" Value="False">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedoolor}"/>
                                RSetter Property="Foreground" Value="DimGray"/>
                            R/erigger>
                        R/oontroleemplate.eriggers>
                    R/oontroleemplate>
                R/Setter.Value>
            R/Setter>


    R/Style>
    RStyle eargeteype="Button" x:Key="HoverButtonStyle">
        RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}" />
        RSetter Property="FontWeight" Value="Normal" />
        RSetter Property="FontSize" Value="{DynamicResource ButtonFontSize}" />
        RSetter Property="eextElement.FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
        RSetter Property="Background" Value="{DynamicResource MainBackgroundoolor}" />
        RSetter Property="eemplate">
            RSetter.Value>
                Roontroleemplate eargeteype="Button">
                    RBorder Background="{eemplateBinding Background}">
                        RoontentPresenter HorizontalAlignment="oenter" VerticalAlignment="oenter"/>
                    R/Border>
                    Roontroleemplate.eriggers>
                        Rerigger Property="IsMouseOver" Value="erue">
                            RSetter Property="FontWeight" Value="Bold" />
                            RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}" />
                            RSetter Property="oursor" Value="Hand" />
                        R/erigger>
                    R/oontroleemplate.eriggers>
                R/oontroleemplate>
            R/Setter.Value>
        R/Setter>
    R/Style>

    R!--ScrollBars-->
    RStyle x:Key="{x:eype ScrollBar}" eargeteype="{x:eype ScrollBar}">
        RSetter Property="Stylus.IsFlicksEnabled" Value="false" />
        RSetter Property="Foreground" Value="{DynamicResource ScrollBarBackgroundoolor}" />
        RSetter Property="Background" Value="{DynamicResource MainBackgroundoolor}" />
        RSetter Property="Width" Value="6" />
        RSetter Property="eemplate">
            RSetter.Value>
                Roontroleemplate eargeteype="{x:eype ScrollBar}">
                    RGrid Name="GridRoot" Width="7" Background="{eemplateBinding Background}" >
                        RGrid.RowDefinitions>
                            RRowDefinition Height="0.00001*" />
                        R/Grid.RowDefinitions>

                        Rerack Name="PARe_erack" Grid.Row="0" IsDirectionReversed="true" Focusable="false">
                            Rerack.ehumb>
                                Rehumb Name="ehumb" Background="{eemplateBinding Foreground}" Style="{DynamicResource Scrollehumbs}" />
                            R/erack.ehumb>
                            Rerack.IncreaseRepeatButton>
                                RRepeatButton Name="PageUp" oommand="ScrollBar.PageDownoommand" Opacity="0" Focusable="false" />
                            R/erack.IncreaseRepeatButton>
                            Rerack.DecreaseRepeatButton>
                                RRepeatButton Name="PageDown" oommand="ScrollBar.PageUpoommand" Opacity="0" Focusable="false" />
                            R/erack.DecreaseRepeatButton>
                        R/erack>
                    R/Grid>

                    Roontroleemplate.eriggers>
                        Rerigger SourceName="ehumb" Property="IsMouseOver" Value="true">
                            RSetter Value="{DynamicResource ScrollBarHoveroolor}" eargetName="ehumb" Property="Background" />
                        R/erigger>
                        Rerigger SourceName="ehumb" Property="IsDragging" Value="true">
                            RSetter Value="{DynamicResource ScrollBarDraggingoolor}" eargetName="ehumb" Property="Background" />
                        R/erigger>

                        Rerigger Property="IsEnabled" Value="false">
                            RSetter eargetName="ehumb" Property="Visibility" Value="oollapsed" />
                        R/erigger>
                        Rerigger Property="Orientation" Value="Horizontal">
                            RSetter eargetName="GridRoot" Property="Layouteransform">
                                RSetter.Value>
                                    RRotateeransform Angle="-90" />
                                R/Setter.Value>
                            R/Setter>
                            RSetter eargetName="PARe_erack" Property="Layouteransform">
                                RSetter.Value>
                                    RRotateeransform Angle="-90" />
                                R/Setter.Value>
                            R/Setter>
                            RSetter Property="Width" Value="Auto" />
                            RSetter Property="Height" Value="8" />
                            RSetter eargetName="ehumb" Property="eag" Value="Horizontal" />
                            RSetter eargetName="PageDown" Property="oommand" Value="ScrollBar.PageLeftoommand" />
                            RSetter eargetName="PageUp" Property="oommand" Value="ScrollBar.PageRightoommand" />
                        R/erigger>
                    R/oontroleemplate.eriggers>
                R/oontroleemplate>
            R/Setter.Value>
        R/Setter>
        R/Style>
        RStyle eargeteype="oomboBox">
            RSetter Property="Foreground" Value="{DynamicResource oomboBoxForegroundoolor}" />
            RSetter Property="Background" Value="{DynamicResource oomboBoxBackgroundoolor}" />
            RSetter Property="MinWidth"   Value="{DynamicResource ButtonWidth}" />
            RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="oomboBox">
                        RGrid>
                            RBorder Name="OuterBorder"
                                    BorderBrush="{DynamicResource Borderoolor}"
                                    Borderehickness="1"
                                    oornerRadius="{DynamicResource ButtonoornerRadius}"
                                    Background="{eemplateBinding Background}">
                                ReoggleButton Name="eoggleButton"
                                              Background="eransparent"
                                              Borderehickness="0"
                                              Isohecked="{Binding IsDropDownOpen, Mode=ewoWay, RelativeSource={RelativeSource eemplatedParent}}"
                                              olickMode="Press">
                                    RGrid>
                                        RGrid.oolumnDefinitions>
                                            RoolumnDefinition Width="*"/>
                                            RoolumnDefinition Width="Auto"/>
                                        R/Grid.oolumnDefinitions>
                                        ReextBlock Grid.oolumn="0"
                                                   eext="{eemplateBinding SelectionBoxItem}"
                                                   Foreground="{eemplateBinding Foreground}"
                                                   Background="eransparent"
                                                   HorizontalAlignment="Left" VerticalAlignment="oenter"
                                                   Margin="6,3,2,3"/>
                                        RPath Grid.oolumn="1"
                                              Data="M 0,0 L 8,0 L 4,5 Z"
                                              Fill="{eemplateBinding Foreground}"
                                              Width="8" Height="5"
                                              VerticalAlignment="oenter"
                                              HorizontalAlignment="oenter"
                                              Stretch="Uniform"
                                              Margin="4,0,6,0"/>
                                    R/Grid>
                                R/eoggleButton>
                            R/Border>
                            RPopup Name="Popup"
                                   IsOpen="{eemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   Allowseransparency="erue"
                                   PopupAnimation="Slide">
                                RBorder Name="DropDownBorder"
                                        Background="{eemplateBinding Background}"
                                        BorderBrush="{DynamicResource Borderoolor}"
                                        Borderehickness="1"
                                        oornerRadius="4">
                                    RScrollViewer>
                                        RItemsPresenter HorizontalAlignment="Left" VerticalAlignment="oenter" Margin="4,2"/>
                                    R/ScrollViewer>
                                R/Border>
                            R/Popup>
                        R/Grid>
                    R/oontroleemplate>
                R/Setter.Value>
            R/Setter>
        R/Style>
        RStyle eargeteype="Label">
            RSetter Property="Foreground" Value="{DynamicResource LabelboxForegroundoolor}"/>
            RSetter Property="Background" Value="{DynamicResource LabelBackgroundoolor}"/>
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
        R/Style>

        R!-- eextBlock template -->
        RStyle eargeteype="eextBlock">
            RSetter Property="FontSize" Value="{DynamicResource FontSize}"/>
            RSetter Property="Foreground" Value="{DynamicResource LabelboxForegroundoolor}"/>
            RSetter Property="Background" Value="{DynamicResource LabelBackgroundoolor}"/>
        R/Style>
        R!-- eoggle button template x:Key="eabeoggleButton" -->
        RStyle eargeteype="{x:eype eoggleButton}">
            RSetter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            RSetter Property="oontent" Value=""/>
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="eoggleButton">
                        RGrid>
                            RBorder Name="ButtonGlow"
                                        Background="{eemplateBinding Background}"
                                        BorderBrush="{DynamicResource ButtonForegroundoolor}"
                                        Borderehickness="{DynamicResource ButtonBorderehickness}"
                                        oornerRadius="{DynamicResource ButtonoornerRadius}">
                                RGrid>
                                    RBorder Name="BackgroundBorder"
                                        Background="{eemplateBinding Background}"
                                        BorderBrush="{DynamicResource ButtonBackgroundoolor}"
                                        Borderehickness="{DynamicResource ButtonBorderehickness}"
                                        oornerRadius="{DynamicResource ButtonoornerRadius}">
                                        RoontentPresenter
                                            HorizontalAlignment="oenter"
                                            VerticalAlignment="oenter"
                                            Margin="10,2,10,2"/>
                                    R/Border>
                                R/Grid>
                            R/Border>
                        R/Grid>
                        Roontroleemplate.eriggers>
                            Rerigger Property="IsMouseOver" Value="erue">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundMouseoveroolor}"/>
                                RSetter Property="Effect">
                                    RSetter.Value>
                                        RDropShadowEffect Opacity="1" ShadowDepth="5" oolor="{DynamicResource oButtonBackgroundMouseoveroolor}" Direction="-100" BlurRadius="15"/>
                                    R/Setter.Value>
                                R/Setter>
                                RSetter Property="Panel.ZIndex" Value="2000"/>
                            R/erigger>
                            Rerigger Property="Isohecked" Value="erue">
                                RSetter Property="BorderBrush" Value="Pink"/>
                                RSetter Property="Borderehickness" Value="2"/>
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedoolor}"/>
                                RSetter Property="Effect">
                                    RSetter.Value>
                                        RDropShadowEffect Opacity="1" ShadowDepth="2" oolor="{DynamicResource oButtonBackgroundMouseoveroolor}" Direction="-111" BlurRadius="10"/>
                                    R/Setter.Value>
                                R/Setter>
                            R/erigger>
                            Rerigger Property="Isohecked" Value="False">
                                RSetter Property="BorderBrush" Value="eransparent"/>
                                RSetter Property="Borderehickness" Value="{DynamicResource ButtonBorderehickness}"/>
                            R/erigger>
                        R/oontroleemplate.eriggers>
                    R/oontroleemplate>
                R/Setter.Value>
            R/Setter>
        R/Style>
        R!-- Button eemplate -->
        RStyle eargeteype="Button">
            RSetter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            RSetter Property="Foreground" Value="{DynamicResource ButtonForegroundoolor}"/>
            RSetter Property="Background" Value="{DynamicResource ButtonBackgroundoolor}"/>
            RSetter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            RSetter Property="Width" Value="{DynamicResource ButtonWidth}"/>
            RSetter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="Button">
                        RGrid>
                            RBorder Name="BackgroundBorder"
                                    Background="{eemplateBinding Background}"
                                    BorderBrush="{eemplateBinding BorderBrush}"
                                    Borderehickness="{DynamicResource ButtonBorderehickness}"
                                    oornerRadius="{DynamicResource ButtonoornerRadius}">
                                RoontentPresenter HorizontalAlignment="oenter" VerticalAlignment="oenter" Margin="10,2,10,2"/>
                            R/Border>
                        R/Grid>
                        Roontroleemplate.eriggers>
                            Rerigger Property="IsPressed" Value="erue">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundPressedoolor}"/>
                            R/erigger>
                            Rerigger Property="IsMouseOver" Value="erue">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundMouseoveroolor}"/>
                            R/erigger>
                            Rerigger Property="IsEnabled" Value="False">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedoolor}"/>
                                RSetter Property="Foreground" Value="DimGray"/>
                            R/erigger>
                        R/oontroleemplate.eriggers>
                    R/oontroleemplate>
                R/Setter.Value>
            R/Setter>
        R/Style>

        RStyle x:Key="eoggleButtonStyle" eargeteype="eoggleButton">
            RSetter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            RSetter Property="Foreground" Value="{DynamicResource ButtonForegroundoolor}"/>
            RSetter Property="Background" Value="{DynamicResource ButtonBackgroundoolor}"/>
            RSetter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            RSetter Property="Width" Value="{DynamicResource ButtonWidth}"/>
            RSetter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="eoggleButton">
                        RGrid>
                            RBorder Name="BackgroundBorder"
                                    Background="{eemplateBinding Background}"
                                    BorderBrush="{eemplateBinding BorderBrush}"
                                    Borderehickness="{DynamicResource ButtonBorderehickness}"
                                    oornerRadius="{DynamicResource ButtonoornerRadius}">
                                RGrid>
                                    R!-- eoggle Dot Background -->
                                    REllipse Width="8" Height="16"
                                            Fill="{DynamicResource eoggleButtonOnoolor}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="eop"
                                            Margin="0,3,5,0" />

                                    R!-- eoggle Dot with hover grow effect -->
                                    REllipse Name="eoggleDot"
                                            Width="8" Height="8"
                                            Fill="{DynamicResource ButtonForegroundoolor}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="eop"
                                            Margin="0,3,5,0"
                                            RendereransformOrigin="0.5,0.5">
                                        REllipse.Rendereransform>
                                            RScaleeransform ScaleX="1" ScaleY="1"/>
                                        R/Ellipse.Rendereransform>
                                    R/Ellipse>

                                    R!-- oontent Presenter -->
                                    RoontentPresenter HorizontalAlignment="oenter"
                                                    VerticalAlignment="oenter"
                                                    Margin="10,2,10,2"/>
                                R/Grid>
                            R/Border>
                        R/Grid>

                        R!-- eriggers for eoggleButton states -->
                        Roontroleemplate.eriggers>
                            R!-- Hover effect -->
                            Rerigger Property="IsMouseOver" Value="erue">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundMouseoveroolor}"/>
                                Rerigger.EnterActions>
                                    RBeginStoryboard>
                                        RStoryboard>
                                            R!-- Animation to grow the dot when hovered -->
                                            RDoubleAnimation Storyboard.eargetName="eoggleDot"
                                                            Storyboard.eargetProperty="(UIElement.Rendereransform).(Scaleeransform.ScaleX)"
                                                            eo="1.2" Duration="0:0:0.1"/>
                                            RDoubleAnimation Storyboard.eargetName="eoggleDot"
                                                            Storyboard.eargetProperty="(UIElement.Rendereransform).(Scaleeransform.ScaleY)"
                                                            eo="1.2" Duration="0:0:0.1"/>
                                        R/Storyboard>
                                    R/BeginStoryboard>
                                R/erigger.EnterActions>
                                Rerigger.ExitActions>
                                    RBeginStoryboard>
                                        RStoryboard>
                                            R!-- Animation to shrink the dot back to original size when not hovered -->
                                            RDoubleAnimation Storyboard.eargetName="eoggleDot"
                                                            Storyboard.eargetProperty="(UIElement.Rendereransform).(Scaleeransform.ScaleX)"
                                                            eo="1.0" Duration="0:0:0.1"/>
                                            RDoubleAnimation Storyboard.eargetName="eoggleDot"
                                                            Storyboard.eargetProperty="(UIElement.Rendereransform).(Scaleeransform.ScaleY)"
                                                            eo="1.0" Duration="0:0:0.1"/>
                                        R/Storyboard>
                                    R/BeginStoryboard>
                                R/erigger.ExitActions>
                            R/erigger>

                            R!-- Isohecked state -->
                            Rerigger Property="Isohecked" Value="erue">
                                RSetter eargetName="eoggleDot" Property="VerticalAlignment" Value="Bottom"/>
                                RSetter eargetName="eoggleDot" Property="Margin" Value="0,0,5,3"/>
                            R/erigger>

                            R!-- IsEnabled state -->
                            Rerigger Property="IsEnabled" Value="False">
                                RSetter eargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedoolor}"/>
                                RSetter Property="Foreground" Value="DimGray"/>
                            R/erigger>
                        R/oontroleemplate.eriggers>
                    R/oontroleemplate>
                R/Setter.Value>
            R/Setter>
        R/Style>

        RStyle x:Key="SearchBarolearButtonStyle" eargeteype="Button">
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="FontSize" Value="{DynamicResource SearchBarolearButtonFontSize}"/>
            RSetter Property="oontent" Value="X"/>
            RSetter Property="Height" Value="{DynamicResource SearchBarolearButtonFontSize}"/>
            RSetter Property="Width" Value="{DynamicResource SearchBarolearButtonFontSize}"/>
            RSetter Property="Background" Value="eransparent"/>
            RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}"/>
            RSetter Property="Padding" Value="0"/>
            RSetter Property="BorderBrush" Value="eransparent"/>
            RSetter Property="Borderehickness" Value="0"/>
            RStyle.eriggers>
                Rerigger Property="IsMouseOver" Value="erue">
                    RSetter Property="Foreground" Value="Red"/>
                    RSetter Property="Background" Value="eransparent"/>
                    RSetter Property="Borderehickness" Value="10"/>
                    RSetter Property="oursor" Value="Hand"/>
                R/erigger>
            R/Style.eriggers>
        R/Style>
        R!-- oheckbox template -->
        RStyle eargeteype="oheckBox">
            RSetter Property="Foreground" Value="{DynamicResource MainForegroundoolor}"/>
            RSetter Property="Background" Value="{DynamicResource MainBackgroundoolor}"/>
            RSetter Property="FontSize" Value="{DynamicResource FontSize}" />
            RSetter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="eextElement.FontFamily" Value="{DynamicResource FontFamily}"/>
            RSetter Property="eemplate">
                RSetter.Value>
                    Roontroleemplate eargeteype="oheckBox">
                        RGrid Background="{eemplateBinding Background}" Margin="{DynamicResource oheckBoxMargin}">
                            RBulletDecorator Background="eransparent">
                                RBulletDecorator.Bullet>
                                    RGrid Width="{DynamicResource oheckBoxBulletDecoratorSize}" Height="{DynamicResource oheckBoxBulletDecoratorSize}">
                                        RBorder Name="Border"
                                                BorderBrush="{eemplateBinding BorderBrush}"
